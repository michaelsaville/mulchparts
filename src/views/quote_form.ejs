<%- include('_head') %>
  <h1><%= part ? 'Request a quote' : 'Contact us' %></h1>

  <% if (part) { %>
    <div class="part-summary">
      <div class="part-summary-title"><%= part.part_name %></div>
      <div class="part-summary-meta">
        <%= part.manufacturer %> · <%= part.machine_model %>
        <% if (part.part_number) { %> · PN <%= part.part_number %><% } %>
      </div>
      <% if (part.description) { %>
        <div class="part-summary-desc"><%= part.description %></div>
      <% } %>
    </div>
  <% } %>

  <% if (error) { %>
    <div class="error-banner"><%= error %></div>
  <% } %>

  <form action="/quote" method="post" class="form-stack">
    <% if (part) { %>
      <input type="hidden" name="part_id" value="<%= part.id %>" />
    <% } %>

    <!-- Honeypot for bots; CSS hides it. -->
    <div class="hp"><label>Website<input type="text" name="website" tabindex="-1" autocomplete="off" /></label></div>

    <label>
      <span>Your name *</span>
      <input type="text" name="customer_name" required value="<%= values.customer_name || '' %>" autocomplete="name" />
    </label>

    <div class="form-row">
      <label>
        <span>Email *</span>
        <input type="email" name="email" required value="<%= values.email || '' %>" autocomplete="email" />
      </label>
      <label>
        <span>Phone</span>
        <input type="tel" name="phone" value="<%= values.phone || '' %>" autocomplete="tel" />
      </label>
    </div>

    <div class="form-row">
      <label>
        <span>Company</span>
        <input type="text" name="company" value="<%= values.company || '' %>" autocomplete="organization" />
      </label>
      <label>
        <span>Quantity</span>
        <input type="text" name="quantity" value="<%= values.quantity || '' %>" placeholder="e.g. 2 sets" />
      </label>
    </div>

    <label>
      <span>Anything we should know?</span>
      <textarea name="message" rows="6" placeholder="Machine year, wear pattern, install timing — anything that helps us spec the right part."><%= values.message || '' %></textarea>
    </label>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary btn-lg">Send request</button>
      <a href="<%= part ? `/parts/${part.id}` : '/parts' %>" class="btn btn-secondary">Cancel</a>
    </div>
    <p class="fine">
      We'll reply via email or phone — typically same business day during posted hours.
      Submitting this form does <strong>not</strong> place an order; pricing follows after a tech reviews specs.
    </p>
  </form>
<%- include('_foot') %>
