# Postgres — set POSTGRES_PASSWORD to a long random string
POSTGRES_PASSWORD=changeme

# Connection string the app uses. Inside docker-compose this resolves
# to the `db` service; for local dev point at 127.0.0.1:5436.
DATABASE_URL=postgres://mulchparts:changeme@db:5432/mulchparts

# Admin panel — Basic Auth. Use a long random password; the panel is
# also expected to live behind the company VPN.
MULCHPARTS_ADMIN_USER=admin
MULCHPARTS_ADMIN_PASSWORD=changeme

# Public-facing URL. Used to build absolute links in outbound quote
# emails (e.g. "view request in admin"). Trailing slash optional.
PUBLIC_BASE_URL=https://mulchparts.pcc2k.com

# App listens on this port inside the container; nginx reverse-proxies
# from :443 to host port -> 3009.
PORT=3000
